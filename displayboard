// ════════════════════════════════════════════════════════════════════════
//  SCREEN 2 — BUTTONS (6 relay toggles)
// ════════════════════════════════════════════════════════════════════════
static void onRelayBtn(lv_event_t *e) {
  int idx = (int)(intptr_t)lv_event_get_user_data(e);
  bool now = !((campData.relayState >> idx) & 1);
  // optimistic local toggle; relay board will confirm via next packet
  if (now) campData.relayState |=  (1 << idx);
  else     campData.relayState &= ~(1 << idx);
  dataUpdated = true;
  // NOTE: to actually switch the relay, the display would send an ESP-NOW
  // command back to the relay board — wired up in a later step.
}

