static void buildPageDots(lv_obj_t *parent, int activeIdx) {
  lv_obj_t *row = lv_obj_create(parent);
  lv_obj_remove_style_all(row);
  lv_obj_set_size(row, 80, 12);
  lv_obj_align(row, LV_ALIGN_BOTTOM_MID, 0, -10);
  lv_obj_set_flex_flow(row, LV_FLEX_FLOW_ROW);
  lv_obj_set_flex_align(row, LV_FLEX_ALIGN_CENTER, LV_FLEX_ALIGN_CENTER, LV_FLEX_ALIGN_CENTER);
  lv_obj_set_style_pad_gap(row, 8, 0);
  for (int i = 0; i < 3; i++) {
    lv_obj_t *d = lv_obj_create(row);
    lv_obj_remove_style_all(d);
    lv_obj_set_size(d, i == activeIdx ? 18 : 7, 7);
    lv_obj_set_style_radius(d, 4, 0);
    lv_obj_set_style_bg_opa(d, LV_OPA_COVER, 0);
    lv_obj_set_style_bg_color(d,
      lv_color_hex(i == activeIdx ? COL_ACCENT : COL_TXT_DIM), 0);
  }
}

