static void styleGlassCard(lv_obj_t *o) {
  lv_obj_set_style_bg_color(o, lv_color_hex(COL_GLASS), 0);
  lv_obj_set_style_bg_opa(o, LV_OPA_COVER, 0);
  // frosted-glass feel: subtle vertical gradient + light border + soft shadow
  lv_obj_set_style_bg_grad_color(o, lv_color_hex(COL_GLASS_HI), 0);
  lv_obj_set_style_bg_grad_dir(o, LV_GRAD_DIR_VER, 0);
  lv_obj_set_style_border_color(o, lv_color_hex(COL_BORDER), 0);
  lv_obj_set_style_border_width(o, 1, 0);
  lv_obj_set_style_border_opa(o, LV_OPA_60, 0);
  lv_obj_set_style_radius(o, 18, 0);
  lv_obj_set_style_shadow_color(o, lv_color_hex(0x000000), 0);
  lv_obj_set_style_shadow_width(o, 24, 0);
  lv_obj_set_style_shadow_opa(o, LV_OPA_40, 0);
  lv_obj_set_style_shadow_ofs_y(o, 6, 0);
  lv_obj_clear_flag(o, LV_OBJ_FLAG_SCROLLABLE);
}

static void styleScreenBg(lv_obj_t *scr) {
  lv_obj_set_style_bg_color(scr, lv_color_hex(COL_BG), 0);
  lv_obj_set_style_bg_grad_color(scr, lv_color_hex(COL_BG2), 0);
  lv_obj_set_style_bg_grad_dir(scr, LV_GRAD_DIR_VER, 0);
}

// forward declaration (onGesture uses it)
void showScreen(Screen s);

// swipe gesture handler — attached to each swipeable screen
static void onGesture(lv_event_t *e) {
  lv_dir_t dir = lv_indev_get_gesture_dir(lv_indev_active());
  if (dir == LV_DIR_LEFT) {
    if (curScreen == SCR_BUTTONS)  showScreen(SCR_MONITOR);
    else if (curScreen == SCR_MONITOR)  showScreen(SCR_LEVELING);
  } else if (dir == LV_DIR_RIGHT) {
    if (curScreen == SCR_LEVELING) showScreen(SCR_MONITOR);
    else if (curScreen == SCR_MONITOR)  showScreen(SCR_BUTTONS);
  }
}

