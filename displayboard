// ════════════════════════════════════════════════════════════════════════
//  LVGL driver callbacks
// ════════════════════════════════════════════════════════════════════════
static void lvglFlushCb(lv_display_t *disp, const lv_area_t *area, uint8_t *px_map) {
  ESP_Panel *p = (ESP_Panel *)lv_display_get_user_data(disp);
  p->getLcd()->drawBitmap(area->x1, area->y1,
                          area->x2 - area->x1 + 1, area->y2 - area->y1 + 1, px_map);
  lv_display_flush_ready(disp);
}
static void lvglTouchCb(lv_indev_t *indev, lv_indev_data_t *data) {
  ESP_Panel *p = (ESP_Panel *)lv_indev_get_user_data(indev);
  if (!p->getTouch()) { data->state = LV_INDEV_STATE_RELEASED; return; }
  ESP_PanelTouchPoint pts[1];
  int n = p->getTouch()->readPoints(pts, 1);
  if (n > 0) {
    data->state = LV_INDEV_STATE_PRESSED;
    data->point.x = pts[0].x;
    data->point.y = pts[0].y;
    lastTouchMs = millis();
    dbgX = pts[0].x; dbgY = pts[0].y;
  } else {
    data->state = LV_INDEV_STATE_RELEASED;
  }
}

// ════════════════════════════════════════════════════════════════════════
//  ESP-NOW
// ════════════════════════════════════════════════════════════════════════
static void onEspNowReceive(const esp_now_recv_info_t *info, const uint8_t *data, int len) {
  if (len != sizeof(CampData)) return;
  memcpy((void *)&campData, data, sizeof(CampData));
  dataUpdated  = true;
  lastEspNowMs = millis();
}

