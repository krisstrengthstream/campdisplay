  buildPageDots(scrLeveling, 2);
}

// ════════════════════════════════════════════════════════════════════════
//  Screen switch with slide animation
// ════════════════════════════════════════════════════════════════════════
void showScreen(Screen s) {
  lv_obj_t *target = nullptr;
  switch (s) {
    case SCR_STANDBY:  target = scrStandby;  break;
    case SCR_BUTTONS:  target = scrButtons;  break;
    case SCR_MONITOR:  target = scrMonitor;  break;
    case SCR_LEVELING: target = scrLeveling; break;
  }
  lv_scr_load_anim(target, LV_SCR_LOAD_ANIM_FADE_IN, 250, 0, false);
  curScreen = s;
  lastTouchMs = millis();
}

// ════════════════════════════════════════════════════════════════════════
//  Live UI updates
// ════════════════════════════════════════════════════════════════════════
static void updateClock() {
  struct tm t;
  if (getLocalTime(&t, 5)) {
    char buf[8];
    strftime(buf, sizeof(buf), "%H:%M", &t);
    lv_label_set_text(lblClock, buf);
  }
}

static void updateUI(const CampData &d) {
  // Buttons
  for (int i = 0; i < 6; i++) {
    bool on = (d.relayState >> i) & 1;
    lv_obj_set_style_bg_color(relayBtns[i],
      lv_color_hex(on ? COL_ACCENT_DK : COL_GLASS), 0);
    lv_obj_set_style_bg_grad_color(relayBtns[i],
      lv_color_hex(on ? COL_ACCENT : COL_GLASS_HI), 0);
    lv_obj_set_style_border_color(relayBtns[i],
      lv_color_hex(on ? COL_ACCENT : COL_BORDER), 0);
    lv_label_set_text(relayBtnStates[i], on ? "ON" : "OFF");
    lv_obj_set_style_text_color(relayBtnStates[i],
      lv_color_hex(on ? COL_TXT : COL_TXT_DIM), 0);
  }

  // Monitor cards
  char buf[16];
  snprintf(buf, sizeof(buf), "%.2f", d.voltage);      lv_label_set_text(monCardVals[0], d.voltage>0.1f?buf:"--");
  snprintf(buf, sizeof(buf), "%.1f", d.current);      lv_label_set_text(monCardVals[1], d.current!=0?buf:"--");
  snprintf(buf, sizeof(buf), "%.1f", d.solarCurrent); lv_label_set_text(monCardVals[2], d.solarCurrent!=0?buf:"--");
  snprintf(buf, sizeof(buf), "%.0f", d.temperature);  lv_label_set_text(monCardVals[3], d.temperature!=0?buf:"--");

  // Leveling readouts
  lv_label_set_text_fmt(lblPitch, "Pitch  %+.1f°", d.pitch);
  lv_label_set_text_fmt(lblRoll,  "Roll   %+.1f°", d.roll);

  const float MAX_DEG = 12.0f;
  int circW = lv_obj_get_width(lv_obj_get_parent(levelBubble));
  float maxR = circW/2.0f - lv_obj_get_width(levelBubble)/2.0f - 6;
  float pN = d.pitch/MAX_DEG, rN = d.roll/MAX_DEG;
  float mag = sqrtf(pN*pN + rN*rN);
  if (mag > 1) { pN/=mag; rN/=mag; }
  lv_obj_align(levelBubble, LV_ALIGN_CENTER, (int)(rN*maxR), (int)(pN*maxR));
  float tilt = sqrtf(d.pitch*d.pitch + d.roll*d.roll);
  uint32_t col = tilt<1.0f?COL_ON:(tilt<5.0f?COL_WARN:COL_DANGER);
  lv_obj_set_style_bg_color(levelBubble, lv_color_hex(col), 0);
  lv_obj_set_style_shadow_color(levelBubble, lv_color_hex(col), 0);
}

static void refreshChart() {
  History *h = (monitorMetric==0)?&histVoltage:(monitorMetric==1)?&histCurrent:
               (monitorMetric==2)?&histSolar:&histTemp;
  if (h->count < 2) return;
  // downsample history into the 120-point chart, autoscale Y
  int pts = lv_chart_get_point_count(monChart);
  float mn = 1e9, mx = -1e9;
  for (int i = 0; i < h->count; i++) {
    float val = h->v[(h->head - h->count + i + HIST_LEN) % HIST_LEN];
    if (val < mn) mn = val; if (val > mx) mx = val;
  }
  if (mx - mn < 0.5f) { mx += 0.5f; mn -= 0.5f; }
  lv_chart_set_range(monChart, LV_CHART_AXIS_PRIMARY_Y, (int)(mn*10), (int)(mx*10));
  for (int i = 0; i < pts; i++) {
    int srcIdx = h->count * i / pts;
    float val = h->v[(h->head - h->count + srcIdx + HIST_LEN) % HIST_LEN];
    lv_chart_set_value_by_id(monChart, monSeries, i, (int)(val*10));
  }
  lv_chart_refresh(monChart);
}

// ════════════════════════════════════════════════════════════════════════
//  Setup
// ════════════════════════════════════════════════════════════════════════
void setup() {
  Serial.begin(115200);
  delay(200);
  Serial.println("Camp Control display booting...");

  lvgl_buf = (uint8_t*)heap_caps_malloc(LVGL_BUF_BYTES, MALLOC_CAP_SPIRAM);
  if (!lvgl_buf) { Serial.println("PSRAM alloc failed — set PSRAM to OPI"); while(1) delay(1000); }

  panel = new ESP_Panel();
  panel->init();
  panel->begin();
  if (panel->getTouch()) {
      Serial.println("Touch: FOUND");
    } else {
      Serial.println("Touch: NOT FOUND - check board config");
    }
  lv_init();
  lv_tick_set_cb(millis);
  lv_display_t *disp = lv_display_create(800, 480);
  lv_display_set_flush_cb(disp, lvglFlushCb);
  lv_display_set_buffers(disp, lvgl_buf, nullptr, LVGL_BUF_BYTES, LV_DISPLAY_RENDER_MODE_PARTIAL);
  lv_display_set_user_data(disp, panel);

  if (panel->getTouch()) {
    lv_indev_t *indev = lv_indev_create();
    lv_indev_set_type(indev, LV_INDEV_TYPE_POINTER);
    lv_indev_set_read_cb(indev, lvglTouchCb);
    lv_indev_set_user_data(indev, panel);
  }

  lvgl_mux = xSemaphoreCreateRecursiveMutex();

  LVGL_LOCK();
  buildStandby();
  buildButtons();
  buildMonitor();
  buildLeveling();
  lv_scr_load(scrStandby);
  LVGL_UNLOCK();

  // ESP-NOW
  WiFi.mode(WIFI_STA);
  WiFi.disconnect();
  if (esp_now_init() == ESP_OK) {
    esp_now_register_recv_cb(onEspNowReceive);
    Serial.println("ESP-NOW ready");
  }

  // Time: set from RTC if available; otherwise shows --:-- until synced.
  // (Later: sync from phone or an RTC module. configTime needs internet.)
  lastTouchMs = millis();
  Serial.println("UI ready");
}

// ════════════════════════════════════════════════════════════════════════
//  Loop
// ════════════════════════════════════════════════════════════════════════
void loop() {
  LVGL_LOCK();

  if (dataUpdated) {
    dataUpdated = false;
    CampData local;
    memcpy(&local, (const void*)&campData, sizeof(CampData));
    updateUI(local);
  }

  // Sample history every 2s
  if (millis() - lastHistMs > 2000) {
    lastHistMs = millis();
    histPush(histVoltage, campData.voltage);
    histPush(histCurrent, campData.current);
    histPush(histSolar,   campData.solarCurrent);
    histPush(histTemp,    campData.temperature);
    if (curScreen == SCR_MONITOR) refreshChart();
  }

  // Clock + standby battery tick every 1s
  static uint32_t lastSec = 0;
  if (millis() - lastSec > 1000) {
    lastSec = millis();
    updateClock();
    if (curScreen == SCR_STANDBY) {
      lv_arc_set_value(battArc, mockBattPct);
      lv_label_set_text_fmt(lblBattPct, "%d%%", mockBattPct);
    }
  }

  // Idle → standby
  if (curScreen != SCR_STANDBY && (millis() - lastTouchMs) > IDLE_TIMEOUT_MS) {
    showScreen(SCR_STANDBY);
  }
  if (dbgX >= 0) {
    Serial.printf("TOUCH x=%d y=%d\n", dbgX, dbgY);
    dbgX = -1;
  }

  lv_timer_handler();
  LVGL_UNLOCK();
  delay(5);
}
